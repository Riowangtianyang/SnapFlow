# SPEC - 环境变量配置

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 数据库
DATABASE_URL=sqlite:///./spec.db

# 视觉模型（用于截图理解）
# 支持: minimax/video-01, openai/gpt-4o, claude-3-opus 等
VISION_MODEL=minimax/video-01
VISION_API_KEY=your_vision_api_key_here
VISION_API_BASE=https://api.minimax.com

# 推理模型（用于意图生成）
# 支持: minimax/moe-01, openai/gpt-4, claude-3-sonnet 等
REASONING_MODEL=minimax/moe-01
REASONING_API_KEY=your_reasoning_api_key_here
REASONING_API_BASE=https://api.minimax.com

# 文件存储
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output